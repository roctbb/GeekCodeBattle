# PostgreSQL
POSTGRES_DB=geekcodebattle
POSTGRES_USER=geekcodebattle
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
REDIS_URL=redis://localhost:6379/0
CELERY_ENABLED=true
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# App secrets
SECRET_KEY=change-me
JWT_SECRET=change-me
DEBUG=false
ENABLE_DEV_LOGIN=false

# Integrations
GEEKCLASS_HOST=https://codingprojects.ru
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8086
GEEKPASTE_API_URL=http://paste:8084/api/external/check

# Callback auth
GEEKPASTE_CALLBACK_REQUIRE_AUTH=true
GEEKPASTE_CALLBACK_EXPECTED_SERVICE=geekpaste
GEEKPASTE_CALLBACK_MAX_AGE_SECONDS=120
GEEKPASTE_CALLBACK_DEDUP_TTL_SECONDS=86400

# Battle rules
ROUND_DURATION_MINUTES=20
POST_WIN_GRACE_MINUTES=5
DISCONNECT_GRACE_SECONDS=300
MATCHMAKING_DELAY_SECONDS=10
ROUND_TIMEOUT_BACKGROUND_ENABLED=false
ROUND_TIMEOUT_POLL_SECONDS=2
AUTO_CREATE_DB=false

# Gunicorn
GUNICORN_WORKERS=1
GUNICORN_TIMEOUT=120
